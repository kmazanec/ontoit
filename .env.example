# Copy to .env and fill in. .env is gitignored — never commit a real key.

# Required: your Anthropic API key (the agent + W-2 vision both use it).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: secret used to sign the session cookie. A random default is used
# if unset, but set a stable value so sessions survive a restart in production.
SESSION_SECRET=change-me-to-a-random-string
